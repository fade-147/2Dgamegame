  dialogueLines:
  - speakerName: "\u9F99\u9A91\u58EB"
    speakerSprite: {fileID: 1066972633, guid: ec6024434cc0c7f4eb61be20590aef7f, type: 3}
    sentenceContent: "\u662F\u65F6\u5019\u628A\u6211\u7684\u88C5\u5907\u4F20\u7ED9\u4F60\u4E86"
  - speakerName: "\uFF08\u54EA\u91CC\u6765\u7684\u5154\u5B50\uFF1F\uFF1F\uFF09"
    speakerSprite: {fileID: 21300000, guid: 79e27342c280d4c419fbd82a9ebedad6, type: 3}
    sentenceContent: "\u795E\u9F99\u88C5\u5907\uFF1F\u5F52\u6211\u5566"
  - speakerName: 
    speakerSprite: {fileID: 0}
    sentenceContent: "\uFF08\u552F\u4E00\u7684\u88C5\u5907\u88AB\u5154\u5B50\u62A2\u8D70\u4E86\uFF09"
  - speakerName: "\u9F99\u9A91\u58EB"
    speakerSprite: {fileID: 1066972633, guid: ec6024434cc0c7f4eb61be20590aef7f, type: 3}
    sentenceContent: "\u90A3\u53EF\u662F\u56FD\u738B\u8D4F\u8D50\u7684\u793C\u7269"
  - speakerName: "\u9F99\u9A91\u58EB"
    speakerSprite: {fileID: 1066972633, guid: ec6024434cc0c7f4eb61be20590aef7f, type: 3}
    sentenceContent: "\u6CA1\u6709\u4E86\u88C5\u5907\uFF0C\u6211\u5C31\u5931\u53BB\u4E86\u795E\u529B\u7684"
  - speakerName: "\u9F99\u9A91\u58EB"
    speakerSprite: {fileID: 1066972633, guid: ec6024434cc0c7f4eb61be20590aef7f, type: 3}
    sentenceContent: "\u9A91\u58EB\uFF0C\u5FEB\u5E2E\u6211\u8FFD\u4E0A\u5B83\uFF01"
